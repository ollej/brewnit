<%= render 'shared/flash_notice' %>
<% if @error.nil? %>
  <% html = j(render partial: 'shared/fermentable_item',
              locals: { fermentable: @fermentable }) %>
  $("<%= html %>").appendTo("#fermentables")
  $("#new_fermentable").trigger("reset");
  $("#fermentables tr[data-fermentable-id=<%= @fermentable.id %>]")
    .effect("highlight", {}, 500);
<% else %>
  <%= render 'shared/flash_error' %>
<% end %>
