<%= render 'shared/flash_notice' %>
<% if @error.nil? %>
  <% html = j(render partial: 'shared/hop_item', locals: { hop: @hop }) %>
  $("<%= html %>").appendTo("#hops")
  $("#new_hop").trigger('reset');
  $("#hops tr[data-hop-id=<%= @hop.id %>]").effect("highlight", {}, 500);
<% else %>
  <%= render 'shared/flash_error' %>
<% end %>
