<%= render 'shared/flash_notice' %>
<% if @error.nil? %>
  <% html = j(render partial: 'shared/mash_step_item',
              locals: { mash_step: @mash_step }) %>
  $("<%= html %>").appendTo("#mash_steps")
  $("#new_mash_step").trigger('reset');
  $("#mash_steps tr[data-mash_step-id=<%= @mash_step.id %>]")
    .effect("highlight", {}, 500);
<% else %>
  <%= render 'shared/flash_error' %>
<% end %>
