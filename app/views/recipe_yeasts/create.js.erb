<%= render 'shared/flash_notice' %>
<% if @error.nil? %>
  <% html = j(render partial: 'shared/yeast_item', locals: { yeast: @yeast }) %>
  $("<%= html %>").appendTo("#yeasts")
  $("#new_yeast").trigger('reset');
  $("#yeasts tr[data-yeast-id=<%= @yeast.id %>]").effect("highlight", {}, 500);
<% else %>
  <%= render 'shared/flash_error' %>
<% end %>
